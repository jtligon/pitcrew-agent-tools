# PITCREW Agent Tools - Environment Variables
# Copy this file to .env and fill in your tokens

# Jira API Token
# Get from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-token-here

# GitHub Personal Access Token (optional - for gh CLI)
# Get from: https://github.com/settings/tokens
GH_TOKEN=your-github-token-here
